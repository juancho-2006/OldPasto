{
  "layer": "top",
  "position": "top",
  "height": 28,
  "margin": "6 6 0 6",

  "modules-left": ["custom/apple","custom/firefox", "hyprland/workspaces"],
  "modules-center": ["clock"],
  "modules-right": [ "network", "battery", "tray", "cpu"],

  /* --- PIXEL APPLE BUTTON (RETRO) --- */
  "custom/apple": {
    "format": "Juanchis",
    "tooltip": false,
    "on-click": "wofi --show drun",
    "on-right-click": "hyprctl dispatch exit"
  },
  "custom/firefox": {
    "format": "  ",
    "tooltip": "Abrir Firefox",
    "on-click": "firefox"
},

  /* --- WORKSPACES --- */
  "hyprland/workspaces": {
    "disable-scroll": true,
    "format": "{name}",
    "on-click": "hyprctl dispatch workspace {name}"
  },

  /* --- CLOCK --- */
  "clock": {
    "format": "{:%A, %d %B %H:%M}",
    "tooltip": true
  },

  /* --- AUDIO PIXEL STYLE --- */
  "pulseaudio": {
    "format": "♪ {volume}%",
    "format-muted": "× mute",
    "tooltip": false
  },

  /* --- NETWORK PIXEL INDICATOR --- */
  "network": {
    "format-wifi": " {essid}",
    "format-ethernet": " {ifname}",
    "format-disconnected": "",
    "tooltip": false
},

  /* --- BATTERY PIXEL BAR --- */
  "battery": {
    "format": "{icon} {capacity}%",
    "format-icons": [
        {"value": "charging", "icon": ""},
        {"value": "full", "icon": ""},
        {"value": "high", "icon": ""},
        {"value": "medium", "icon": ""},
        {"value": "low", "icon": ""},
        {"value": "empty", "icon": ""}
],
"tooltip": true
},

  /* --- CPU RETRO --- */
  "cpu": {
    "format": "CPU   {usage}%"
  }
}


